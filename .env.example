# Required: value between /d/ and /edit in the Google Sheet URL
SPREADSHEET_ID=YOUR_GOOGLE_SPREADSHEET_ID

# Optional sheet-tab names
APPLICATIONS_SHEET=Applications
PROCESSED_SHEET=ProcessedEmails
REVIEW_SHEET=Review

# Gmail history window
START_DATE=2025/06/01

# Optional sender filters
BLOCKED_SENDER_DOMAINS=
TRUSTED_SENDER_DOMAINS=

# Optional custom local paths
# GOOGLE_CREDENTIALS_FILE=/absolute/path/to/credentials.json
# GOOGLE_TOKEN_FILE=/absolute/path/to/token.json
# LOCK_FILE=/absolute/path/to/.job_tracker.lock
